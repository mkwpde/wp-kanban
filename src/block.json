{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mfgmicha/kanban-board",
	"version": "0.1.0",
	"title": "Kanban Board",
	"category": "widgets",
	"icon": "clipboard",
