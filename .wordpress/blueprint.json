{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"landingPage": "/kanban/",
	"preferredVersions": {
		"wp": "latest",
		"php": "8.4"
	},
	"steps": [
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "url",
				"url": "https://github.com/mkwpde/wp-kanban/archive/refs/heads/main.zip"
			}
		},
		{
			"step": "activatePlugin",
			"pluginPath": "wp-kanban-main/plugin.php"
		},
		{
			"step": "importWxr",
			"file": {
				"resource": "bundled",
				"path": "sample-data.wxr"
			}
		},
		{
			"step": "wp-cli",
			"command": "wp post create --post_type=page --post_title='Kanban Board' --post_name='kanban' --post_content='<!-- wp:mkwpde/kanban-board /-->' --post_status=publish"
		}
	]
}